{
  "info": {
    "name": "Mini Project Management System",
    "_postman_id": "9f45a1d2-2a0b-4b0d-a3d2-6d56b5a2c3b1",
    "description": "Projects + Tasks APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "projectId", "value": "1" },
    { "key": "taskId", "value": "1" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create project",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Website Refresh\",\n  \"description\": \"Update landing page + improve mobile performance.\"\n}\n"
            },
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] }
          }
        },
        {
          "name": "List projects (paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/projects?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["projects"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get project by id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}"] }
          }
        },
        {
          "name": "Delete project by id",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects", "{{projectId}}"] }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create task (for project)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Design hero section\",\n  \"description\": \"Modern layout and clear call-to-action.\",\n  \"status\": \"todo\",\n  \"priority\": \"medium\",\n  \"due_date\": \"2026-05-01T00:00:00.000Z\"\n}\n"
            },
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks"]
            }
          }
        },
        {
          "name": "List tasks (filter + sort + paginate)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks?status=todo&sort=due_date&order=asc&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks"],
              "query": [
                { "key": "status", "value": "todo" },
                { "key": "sort", "value": "due_date" },
                { "key": "order", "value": "asc" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Update task",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in-progress\",\n  \"priority\": \"high\"\n}\n"
            },
            "url": { "raw": "{{baseUrl}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["tasks", "{{taskId}}"] }
          }
        },
        {
          "name": "Delete task",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["tasks", "{{taskId}}"] }
          }
        }
      ]
    }
  ]
}

